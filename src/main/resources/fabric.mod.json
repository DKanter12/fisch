      "com.fisch.FischMod"
    ],
    "client": [
      "com.fisch.client.FischModClient"
    ]
  },
	"mixins": [
      "fisch.mixins.json",
		{
			"config": "fisch.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
